# Normalização padrão: detecta texto automaticamente e converte para LF no repositório
* text=auto eol=lf

# ---- Código-fonte ----
*.py    text eol=lf
*.pyw   text eol=lf

# ---- Scripts de shell ----
*.sh    text eol=lf

# ---- Scripts Windows (precisam de CRLF para funcionar) ----
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# ---- Texto / documentação ----
*.md    text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.toml  text eol=lf

# ---- Binários (sem conversão de linha) ----
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.exe   binary
*.dll   binary
*.pyc   binary
*.pyd   binary
*.pyo   binary
